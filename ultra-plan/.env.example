# Content Intelligence Agent — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.

# ──── Database (Supabase via Supavisor pooler) ──────────────
# Note: Username is postgres.[PROJECT_REF], NOT just postgres
# Note: URL-encode special chars in password (@ → %40)
DATABASE_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres"
DATABASE_URL_DIRECT="postgresql://postgres.[PROJECT]:[PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# ──── Auth (Clerk) ───────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ──── Security ───────────────────────────────────────────────
OAUTH_ENCRYPTION_KEY=""  # 32-byte hex for AES-256-GCM token encryption. Generate: openssl rand -hex 32

# ──── Background Jobs (Inngest) ──────────────────────────────
INNGEST_SIGNING_KEY=""
INNGEST_EVENT_KEY=""

# ──── n8n Webhooks ───────────────────────────────────────────
N8N_WEBHOOK_SECRET=""  # HMAC-SHA256 shared secret. Generate: openssl rand -hex 32
N8N_INSTANCE_URL="https://full-funnel.app.n8n.cloud"

# ──── AI Providers ───────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."       # Claude models (hook, body, voice scoring)
OPENAI_API_KEY="sk-..."              # GPT fallback models
GOOGLE_AI_API_KEY=""                  # Gemini (anti-AI audit fallback)
VOYAGE_API_KEY=""                     # Voyage-3 embeddings
COHERE_API_KEY=""                     # Rerank-3
GEMINI_API_KEY=""                     # Gemini (alias for GOOGLE_AI_API_KEY)
OPENROUTER_API_KEY=""                 # OpenRouter (multi-model gateway)

# ──── Supabase (for direct client access if needed) ──────────
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ──── Platform OAuth (per-connector, stored encrypted in DB) ─
# These are NOT env vars — OAuth tokens are stored encrypted in
# the oauth_credentials table via the Token Manager.
# Only the OAUTH_ENCRYPTION_KEY above is an env var.

# ──── X/Twitter Cost Tracking ────────────────────────────────
# X API is pay-per-use since Feb 2026:
# $0.015/post (no URL), $0.20/post (with URL)
# Costs tracked in post_results.platform_cost_cents

# ──── Optional ───────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL="http://localhost:3000"  # For webhook callback URLs
# SENTRY_DSN=""                                # Error monitoring (optional)
# VERCEL_URL=""                                # Auto-set by Vercel
# LOG_LEVEL="info"                             # debug | info | warn | error
